# ----------------------------------------------------------------------------
# FluentBank environment variables
#
# The app runs fully WITHOUT these — by default it persists to localStorage so
# you can demo every feature immediately. Provide these to enable the Supabase
# backend (auth + Postgres persistence). See README.md → "Connecting Supabase".
# ----------------------------------------------------------------------------

# Your Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe to expose to the browser; protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to "true" to make the app use Supabase instead of local storage.
# Leave unset/false to run in local-first mode.
NEXT_PUBLIC_USE_SUPABASE=false
